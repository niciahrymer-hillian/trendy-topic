DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/global_ai_conversations
HF_TOKEN=your_huggingface_token_here

# Translation provider options
TRANSLATION_PROVIDER=deepl
DEEPL_API_KEY=your_deepl_key_here
GOOGLE_CLOUD_TRANSLATION_API_KEY=your_google_key_here
LIBRETRANSLATE_URL=http://localhost:5000

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# LLM provider for AI topic extraction (Groq)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
