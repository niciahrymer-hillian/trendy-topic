# Trendy Topic — secrets & configuration template
# -------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
#   cp .env.example .env
#
# Only DATABASE_URL is required for the database-backed features. The API keys
# are optional and only needed for the features that use them (see comments).

# --- Database (required for DB-backed endpoints) ---
# Local docker-compose injects this automatically; set it for any other host.
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://trendy:trendy@localhost:5432/trendy

# --- PostgreSQL container credentials (used by docker-compose `db` service) ---
# Change these for any non-local deployment.
POSTGRES_USER=trendy
POSTGRES_PASSWORD=trendy
POSTGRES_DB=trendy

# --- LLM provider (AI insights / topic extraction / "Ask the Dataset") ---
# Required for the AI features. Groq is the default provider.
GROQ_API_KEY=
# Optional alternate LLM provider.
ANTHROPIC_API_KEY=
# Optional overrides:
# LLM_PROVIDER=groq            # groq | anthropic
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Voice briefings (text-to-speech) ---
# Required only for the AI voice summary feature.
ELEVENLABS_API_KEY=

# --- Translation ---
# Required only for the translation feature.
# TRANSLATION_PROVIDER controls which backend is used: deep_translator (free,
# default) | groq | google | deepl
# TRANSLATION_PROVIDER=deep_translator
GOOGLE_CLOUD_TRANSLATION_API_KEY=
# Path to a Google service-account JSON key (alternative to the API key above).
GOOGLE_APPLICATION_CREDENTIALS=
DEEPL_API_KEY=

# --- Admin endpoints ---
# Token required to call the Dewey reindex/admin endpoints. Leave blank to
# disable those endpoints entirely.
DEWEY_ADMIN_TOKEN=
